{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "title": "inbox",
    "type": "object",
    "properties": {
        "MessageList": {
            "type": "object",
            "properties": {
                "avatarID": {
                    "type": "string"
                },
                "Message": {
                    "type": "object",
                    "properties": {
                        "_attributes": {
                            "type": "object",
                            "properties": {
                                "id": {
                                    "type": "string"
                                },
                                "type": {
                                    "type": "string"
                                },
                                "read": {
                                    "type": "string"
                                }
                            }
                        },
                        "Date": {
                            "type": "object",
                            "properties": {
                                "Year": {
                                    "type": "string"
                                },
                                "Month": {
                                    "type": "string"
                                },
                                "Day": {
                                    "type": "string"
                                }
                            }
                        },
                        "Time": {
                            "type": "object",
                            "properties": {
                                "Hour": {
                                    "type": "string"
                                },
                                "Minute": {
                                    "type": "string"
                                },
                                "Second": {
                                    "type": "string"
                                }
                            }
                        },
                        "SenderID": {
                            "type": "string"
                        },
                        "SenderName": {
                            "type": "string"
                        },
                        "Subject": {
                            "type": "string"
                        },
                        "MessageText": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    }
}